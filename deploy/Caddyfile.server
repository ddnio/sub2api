}

# =============================================================================
# AlphaPick
# =============================================================================
pick.nanafox.com {
	tls {
		protocols tls1.2 tls1.3
	}

	encode {
		zstd
		gzip 6
		minimum_length 256
		match {
			header Content-Type text/*
			header Content-Type application/json*
			header Content-Type application/javascript*
		}
	}

	# Inference API
	reverse_proxy /ai/* 127.0.0.1:8765 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	reverse_proxy /health 127.0.0.1:8765
	reverse_proxy /healthz 127.0.0.1:8765
	reverse_proxy /ready 127.0.0.1:8765
	reverse_proxy /strategies 127.0.0.1:8765
	reverse_proxy /infer 127.0.0.1:8765
	reverse_proxy /recommend 127.0.0.1:8765
	reverse_proxy /docs 127.0.0.1:8765
	reverse_proxy /openapi.json 127.0.0.1:8765

	# Game service
	reverse_proxy /games/* 127.0.0.1:8767

	# Default - inference service
	handle {
		reverse_proxy 127.0.0.1:8765 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	log {
		output file /var/log/caddy/alphapick.log {
			roll_size 50mb
			roll_keep 5
			roll_keep_for 720h
		}
		format json
		level INFO
	}

	handle_errors {
		respond "{err.status_code} {err.status_text}"
	}
}

# =============================================================================
# Nanafox Landing Page
# =============================================================================
nanafox.com, www.nanafox.com {
	tls {
		protocols tls1.2 tls1.3
	}

	root * /data/service/nanafox-landing
	file_server

	handle_errors {
		respond "{err.status_code} {err.status_text}"
	}
}
